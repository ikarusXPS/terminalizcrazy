# TerminalizCrazy Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# AI Provider API Keys (at least one required)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
OPENAI_API_KEY=sk-your-key-here

# Optional: Preferred AI Provider (anthropic or openai)
AI_PROVIDER=anthropic

# Optional: Collaboration Server (for session sharing)
# SIGNALING_SERVER_URL=wss://your-signaling-server.com

# Optional: Debug mode (true/false)
# DEBUG=false

# Optional: Log level (debug, info, warn, error)
# LOG_LEVEL=info
