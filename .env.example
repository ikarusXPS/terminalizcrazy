# TerminalizCrazy Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# Default: Ollama with Gemma4 (local, no API key required)
# Just run: ollama pull gemma4 && ollama serve
AI_PROVIDER=ollama
OLLAMA_MODEL=gemma4

# Cloud Provider API Keys (optional alternatives)
# GEMINI_API_KEY=AIzaSy-your-key-here
# ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
# OPENAI_API_KEY=sk-your-key-here

# Optional: Collaboration Server (for session sharing)
# SIGNALING_SERVER_URL=wss://your-signaling-server.com

# Optional: Debug mode (true/false)
# DEBUG=false

# Optional: Log level (debug, info, warn, error)
# LOG_LEVEL=info
